{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "sourceMap": true
  },
  "exclude": ["node_modules", "dist", "vitest.config.ts", "**/__tests__/**", "**/*.test.ts", "**/*.test.tsx", "test/setup.ts", "test/__mocks__/**", "test/manifest.test.ts"]
}
