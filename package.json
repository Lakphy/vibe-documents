{
  "name": "vibe-documents",
  "displayName": "Vibe Documents - Cursor-style Markdown Preview",
  "description": "A beautiful Markdown preview extension inspired by Cursor's rendering style, with Mermaid, KaTeX, Shiki code highlighting and more.",
  "version": "0.3.0",
  "publisher": "lakphy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lakphy/vibe-documents"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:csv",
    "onLanguage:excalidraw",
    "onCustomEditor:vibeDocuments.markdownEditor",
    "onCustomEditor:vibeDocuments.csvEditor",
    "onCustomEditor:vibeDocuments.excalidrawEditor",
    "onCommand:vibeDocuments.showExcalidrawPreview",
    "onCommand:vibeDocuments.showCsvPreview"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vibeDocuments.showPreview",
        "title": "Vibe: Open Markdown Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "vibeDocuments.showPreviewToSide",
        "title": "Vibe: Open Markdown Preview to the Side",
        "icon": "$(open-preview)"
      },
      {
        "command": "vibeDocuments.toggleMode",
        "title": "Vibe: Toggle Preview/Edit Mode",
        "icon": "$(edit)"
      },
      {
        "command": "vibeDocuments.showExcalidrawPreview",
        "title": "Vibe: Open Excalidraw Editor",
        "icon": "$(open-preview)"
      },
      {
        "command": "vibeDocuments.showCsvPreview",
        "title": "Vibe: Open CSV Preview",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vibeDocuments.showPreview",
          "when": "editorLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "vibeDocuments.showExcalidrawPreview",
          "when": "resourceExtname == .excalidraw",
          "group": "navigation"
        },
        {
          "command": "vibeDocuments.showCsvPreview",
          "when": "resourceExtname == .csv",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "vibeDocuments.showPreview",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "vibeDocuments.showExcalidrawPreview",
          "when": "resourceExtname == .excalidraw",
          "group": "navigation"
        },
        {
          "command": "vibeDocuments.showCsvPreview",
          "when": "resourceExtname == .csv",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "excalidraw",
        "extensions": [
          ".excalidraw"
        ],
        "aliases": [
          "Excalidraw"
        ]
      }
    ],
    "customEditors": [
      {
        "viewType": "vibeDocuments.markdownEditor",
        "displayName": "Vibe Markdown Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          },
          {
            "filenamePattern": "*.markdown"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "vibeDocuments.csvEditor",
        "displayName": "Vibe CSV Editor",
        "selector": [
          {
            "filenamePattern": "*.csv"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "vibeDocuments.excalidrawEditor",
        "displayName": "Vibe Excalidraw Editor",
        "selector": [
          {
            "filenamePattern": "*.excalidraw"
          }
        ],
        "priority": "option"
      }
    ],
    "keybindings": [
      {
        "command": "vibeDocuments.showPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == markdown"
      },
      {
        "command": "vibeDocuments.toggleMode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "vibeDocumentsPreviewFocused"
      },
      {
        "command": "vibeDocuments.showExcalidrawPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "resourceExtname == .excalidraw"
      },
      {
        "command": "vibeDocuments.showCsvPreview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "resourceExtname == .csv"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "webpack --mode production",
    "build:webview": "vite build --config vite.config.webview.ts && node scripts/strip-webview-sourcemaps.mjs",
    "dev": "npm run dev:ext & npm run dev:webview",
    "dev:ext": "webpack --mode development --watch",
    "dev:webview": "vite build --config vite.config.webview.ts --watch",
    "package": "vsce package",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "perf:budget": "node scripts/check-performance-budget.mjs"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fast-diff": "^1.1.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "ts-loader": "^9.5.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@milkdown/kit": "^7.20.0",
    "@milkdown/react": "^7.20.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-virtual": "^3.13.24",
    "fast-diff": "^1.3.0",
    "lucide-react": "^1.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "streamdown": "^2.5.0"
  }
}
